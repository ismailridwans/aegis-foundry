# Aegis Foundry configuration. Copy to .env (or export) — never commit real values.

# "mock" runs the full pipeline offline with fixtures; "live" talks to real Splunk.
AEGIS_MODE=mock

# --- Splunk MCP Server (live mode) ---
SPLUNK_MCP_URL=https://your-stack.splunkcloud.com:8089/services/mcp
SPLUNK_MCP_TOKEN=
# Management REST API for governed deployments (Deployer agent)
SPLUNK_REST_URL=https://your-stack.splunkcloud.com:8089
SPLUNK_REST_TOKEN=
SPLUNK_VERIFY_TLS=true

# --- Data ---
AEGIS_BACKTEST_INDEX=botsv3
AEGIS_AUDIT_INDEX=aegis_audit

# --- Models ---
# Live mode without Splunk Cloud: serve the open-weight models locally
# (e.g. `ollama pull gpt-oss:20b` and Foundation-Sec via vLLM) and point here.
AEGIS_LLM_BASE_URL=http://localhost:11434/v1
AEGIS_LLM_API_KEY=ollama
AEGIS_SECURITY_MODEL=foundation-sec-1.1-8b-instruct
AEGIS_GENERAL_MODEL=gpt-oss-20b
AEGIS_FORECAST_MODEL=CDTSM

# --- Governance ---
AEGIS_FP_BUDGET_WEEKLY=25
AEGIS_MAX_TUNING_ITERATIONS=3
AEGIS_AUTO_APPROVE=false
AEGIS_SHADOW_FIRST=true
